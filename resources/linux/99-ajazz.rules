# udev rules for AJAZZ / Mirabox devices.
#
# These rules use `TAG+="uaccess"` which tells systemd-logind to grant
# read/write access to the *currently logged-in user* automatically, via
# ACLs on the device node. There is no need to:
#
#   * belong to any group (no `plugdev`, no `input`)
#   * log out and back in
#   * run the app as root
#   * replug the device
#
# Just install this file, reload udev, and AJAZZ Control Center works.
#
# Install:
#   sudo install -m 644 99-ajazz.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# Linux packages (deb/rpm/flatpak) do this automatically in their
# post-install step; you only need to run the commands above if you are
# building from source.
#
# Backend scope: AJAZZ Control Center links the `hidapi::hidapi` umbrella
# target which, on Linux, resolves to `hidapi_hidraw` — the kernel-native
# `/dev/hidraw*` backend. The libusb backend is not used by our binary.
# Only the `KERNEL=="hidraw*"` matchers are therefore needed; we
# deliberately do NOT publish `SUBSYSTEM=="usb"` rules so our policy
# stays scoped to the device class we actually open.
#   Reference: hidapi-0.14.0 src/CMakeLists.txt sets
#   EXPORT_ALIAS=hidraw whenever HIDAPI_WITH_HIDRAW is built, which is
#   the default on Linux (audit finding S8, 2026-04-27).

# ---------------------------------------------------------------------------
# Stream decks (Mirabox HSV293S family, AKP153 / AKP153E / AKP03 / AKP05)
# ---------------------------------------------------------------------------
KERNEL=="hidraw*",    ATTRS{idVendor}=="0300", MODE="0660", TAG+="uaccess"

# ---------------------------------------------------------------------------
# VIA-compatible AJAZZ keyboards (SONiX vendor prefix 0x3151)
# ---------------------------------------------------------------------------
KERNEL=="hidraw*",    ATTRS{idVendor}=="3151", MODE="0660", TAG+="uaccess"

# ---------------------------------------------------------------------------
# AJAZZ AJ-series mice
# ---------------------------------------------------------------------------
# Two distinct VID spaces are used by the AJ-series mouse line, surfaced by
# the 2026-04-29 vendor static-analysis pass (see
# docs/research/vendor-protocol-notes.md Findings 8 + 9):
#
#   * VID 0x248A — AJ139 / AJ159 / AJ179 family (USB-wired and 2.4GHz dongle
#     modes). The vendor's own driver enumerates them under PIDs
#     0x5C2E / 0x5D2E / 0x5E2E (wired) and 0x5C2F (dongle).
#
#   * VID 0x249A — alternate VID for the 2.4GHz dongle of the same family
#     (vendor exposes it under both VIDs depending on USB stack path).
#
#   * VID 0x3554 — AJ199 family (AJ199, AJ199 Max, AJ199 Carbon Fiber). PIDs
#     in the 0xF500-0xF5D5 range; M_PID list `F500 / F546 / F566` for wired,
#     D_PID list `F501 / F545 / F547 / F564 / F567 / F5D5` for dongle.
#
# Pre-2026-04-29 only `idVendor=="3554"` was tagged here, which meant AJ159
# / AJ139 / AJ179 mice plugged into a Linux host received no `uaccess` ACL
# and the app could not open the device. Tracking entry: TODO.md →
# "AJ-series VID:PID enumeration drift".
KERNEL=="hidraw*",    ATTRS{idVendor}=="248a", MODE="0660", TAG+="uaccess"
KERNEL=="hidraw*",    ATTRS{idVendor}=="249a", MODE="0660", TAG+="uaccess"
KERNEL=="hidraw*",    ATTRS{idVendor}=="3554", MODE="0660", TAG+="uaccess"

# ---------------------------------------------------------------------------
# AJAZZ AK980 PRO and other Microdia-chipset AK keyboards (vendor 0x0c45)
# ---------------------------------------------------------------------------
KERNEL=="hidraw*",    ATTRS{idVendor}=="0c45", MODE="0660", TAG+="uaccess"
